# API Configuration
# Base URL for backend API (when integrated with real backend)
# Use HTTPS in production, HTTP only for local development
VITE_API_BASE_URL=https://api.example.com

# AI Service Configuration
# URL for AI vision services (OpenAI, Google Cloud Vision, Azure, etc.)
VITE_AI_SERVICE_URL=
VITE_AI_API_KEY=

# Feature Flags
# Enable/disable FleetScan mobile inspection module
VITE_ENABLE_FLEETSCAN=true

# Enable/disable AI features (damage detection, OCR)
VITE_ENABLE_AI_FEATURES=false

# Application Settings
# Application name shown in UI
VITE_APP_NAME="Fleet Command"

# Default locale
VITE_DEFAULT_LOCALE=en-US

# Debug mode (shows additional logging)
VITE_DEBUG_MODE=false
